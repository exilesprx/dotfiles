[global]
    ### Display & Geometry ###
    monitor = 2
    follow = none
    width = 300
    height = (0, 300)
    origin = bottom-right
    offset = (30, 40)
    scale = 0
    notification_limit = 5

    ### Progress bar (Catppuccin Mauve/Surface0) ###
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 0
    
    ### UI Elements ###
    transparency = 16
    separator_height = 2
    padding = 8
    horizontal_padding = 8
    text_icon_padding = 4
    frame_width = 2
    # Catppuccin Mauve for the frame
    frame_color = "#cba6f7" 
    gap_size = 5
    separator_color = frame
    sort = yes
    idle_threshold = 0

    ### Text ###
    # Standard Noto Sans for clarity on the Zenbook display
    font = Noto Sans Regular 9
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = true
    show_indicators = no

    ### Icons ###
    icon_position = left
    min_icon_size = 0
    max_icon_size = 32
    icon_path = /usr/share/icons/Qogir/16/status:/usr/share/icons/Qogir/16/devices/:/usr/share/icons/Qogir/24/panel/:/usr/share/icons/Qogir/16/apps/:/usr/share/pixmaps/:/usr/share/icons/Qogir/scalable/apps/
    
    ### History & Misc ###
    sticky_history = false
    history_length = 20
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 7
    corners = all

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

### Urgency Sections (Catppuccin Mocha Palette) ###

[urgency_low]
    # Surface0 Background, Text Foreground
    background = "#313244"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 5
    icon = /usr/share/icons/Qogir/16/status/package-installed-outdated.svg

[urgency_normal]
    # Surface0 Background, Lavender Frame
    background = "#313244"
    foreground = "#cdd6f4"
    frame_color = "#b4befe"
    timeout = 5
    override_pause_level = 30
    icon = /usr/share/icons/Qogir/16/emblems/emblem-question.svg

[urgency_critical]
    # Surface0 Background, Red Frame/Text for attention
    background = "#313244"
    foreground = "#f38ba8"
    frame_color = "#fab387"
    timeout = 120
    icon = /usr/share/icons/Qogir/16/actions/dialog-warning.svg

[stack-volumes]
    appname = "some_volume_notifiers"
    set_stack_tag = "volume"
